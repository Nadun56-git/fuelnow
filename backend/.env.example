# FuelNow Backend Environment Configuration Example
# Copy this file to .env and update the values

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# Format: mongodb://username:password@host:port/database
MONGO_URI=mongodb+srv://Nadun:2002@cluster.hdc7bci.mongodb.net/?appName=cluster

# CORS Configuration (Frontend URL)
ALLOWED_ORIGIN=http://localhost:5173

# Proximity Settings (in kilometers)
# Users must be within this distance to update fuel availability
PROXIMITY_RADIUS_KM=0.5

# Optional: API Keys (for future extensions)
# NOMINATIM_USER_AGENT=FuelNow/1.0
